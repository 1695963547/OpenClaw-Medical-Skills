# ─── Secrets & Local Config ───────────────────────────────
# Local LLM configuration with real API keys — DO NOT commit
llm_local_config.py
*.local.py
.env
.env.local

# ─── Runtime Artifacts ──────────────────────────────────────
# Vector database (ChromaDB) — large binary, regenerated by app
chroma_db/
**/chroma_db/
**/chroma_squidpy_db/
*.sqlite3
*.db
*.bin
*.h5
*.hdf5

# ─── Logs & Benchmarks ──────────────────────────────────────
# May contain internal API URLs, model decisions, and user queries
logs/
*.log
agent_run.jsonl

# ─── Python Cache ───────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*$py.class
*.so
.Python

# ─── Test / Workspace Outputs ──────────────────────────────
TestQuestion/
workspace/
workspace/.cache/
workspace/output/

# ─── Skill Bundled Data (large binary datasets / figures) ──
# cellagent-annotation: bundled upstream paper repo (datasets + figures)
skills/cellagent-annotation/repo/
# timesfm-forecasting: generated example outputs
skills/timesfm-forecasting/examples/*/output/
# genome-compare: bundled 23andme raw genotype data
skills/genome-compare/data/
# trialgpt-matching: bundled TREC clinical trial retrieval datasets
skills/trialgpt-matching/repo/dataset/
# Generic large/binary types inside skills/
*.npz
*.npy
*.parquet
*.ipynb_checkpoints/

# ─── Tooling & IDE Config (per-user) ───────────────────────
.vscode/
.idea/
.claude/
.firecrawl/

# ─── Build / Distribution ───────────────────────────────────
build/
dist/
*.egg-info/
.eggs/

# ─── Virtual Env ────────────────────────────────────────────
venv/
.venv/
env/
conda-env/

# ─── OS & Misc ──────────────────────────────────────────────
*.swp
.DS_Store
Thumbs.db
desktop.ini

# ─── Runtime Stats (regenerated at runtime) ────────────────
skill_stats.json
